# 小豆子旅行轨迹 - 配置文件模板
# 复制此文件为 .env 并填入真实配置信息

# ========================================
# 微信小程序配置
# ========================================
WECHAT_APP_ID=your_wechat_app_id_here
WECHAT_APP_SECRET=your_wechat_app_secret_here

# ========================================
# 微信云开发配置
# ========================================
CLOUD_ENV_ID=your_cloud_env_id_here

# ========================================
# 腾讯地图配置
# ========================================
TENCENT_MAP_KEY=your_tencent_map_key_here
TENCENT_MAP_SK=your_tencent_map_sk_here

# ========================================
# 高德地图配置（备用）
# ========================================
AMAP_KEY=your_amap_key_here
AMAP_SECRET=your_amap_secret_here

# ========================================
# 博物馆数据源配置
# ========================================
MUSEUM_API_URL=https://api.ncha.gov.cn/api/v1
MUSEUM_API_KEY=your_museum_api_key_here
MUSEUM_API_TOKEN=Bearer_your_token_here

# ========================================
# GitHub备用数据源配置
# ========================================
GITHUB_MUSEUM_REPO=https://raw.githubusercontent.com/xxx/xxx/master/museums.json

# ========================================
# 其他配置
# ========================================
DEBUG=false
API_TIMEOUT=30000
IMAGE_COMPRESSION_QUALITY=80
IMAGE_MAX_WIDTH=1920
TIMELINE_SORT=asc
