/* 全局样式 */

/* 页面容器 */
page {
  background-color: #F5F5F5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

/* 容器 */
.container {
  padding: 20rpx;
}

/* 卡片 */
.card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

/* 按钮 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  font-size: 32rpx;
  line-height: 88rpx;
  transition: all 0.3s ease;
}

.btn-primary {
  background-color: #FF6B6B;
  color: #FFFFFF;
}

.btn-secondary {
  background-color: #4ECDC4;
  color: #FFFFFF;
}

.btn-active {
  background-color: #FFD93D;
  color: #333333;
}

/* 文本 */
.text-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
}

.text-subtitle {
  font-size: 32rpx;
  font-weight: 500;
  color: #666666;
}

.text-body {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
}

.text-muted {
  font-size: 24rpx;
  color: #999999;
}

/* 图标 */
.icon {
  width: 40rpx;
  height: 40rpx;
}

/* 分割线 */
.divider {
  height: 2rpx;
  background-color: #E0E0E0;
  margin: 30rpx 0;
}

/* 徽章 */
.badge {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 4rpx;
  font-size: 22rpx;
  line-height: 1.2;
}

.badge-success {
  background-color: #4CAF50;
  color: #FFFFFF;
}

.badge-warning {
  background-color: #FF9800;
  color: #FFFFFF;
}

.badge-info {
  background-color: #2196F3;
  color: #FFFFFF;
}

/* 空状态 */
/* empty-state {
  display: flex;
  flex-direction: column;
  align:: center;
  padding: 100rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}
